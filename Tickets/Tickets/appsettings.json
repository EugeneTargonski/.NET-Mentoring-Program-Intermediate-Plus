{
  "CosmosDb": {
    "EventDb": {
      "EndpointUri": "https://{your-event-cosmos-account}.documents.azure.com:443/",
      "PrimaryKey": "{your-event-primary-key}",
      "DatabaseName": "EventDb",
      "ApplicationName": "TicketsApp-EventService",
      "AllowBulkExecution": true,
      "MaxRetryAttemptsOnRateLimitedRequests": 5,
      "MaxRetryWaitTimeOnRateLimitedRequests": 30
    },
    "InventoryDb": {
      "EndpointUri": "https://{your-inventory-cosmos-account}.documents.azure.com:443/",
      "PrimaryKey": "{your-inventory-primary-key}",
      "DatabaseName": "InventoryDb",
      "ApplicationName": "TicketsApp-InventoryService",
      "AllowBulkExecution": true,
      "MaxRetryAttemptsOnRateLimitedRequests": 5,
      "MaxRetryWaitTimeOnRateLimitedRequests": 30
    },
    "TransactionDb": {
      "EndpointUri": "https://{your-transaction-cosmos-account}.documents.azure.com:443/",
      "PrimaryKey": "{your-transaction-primary-key}",
      "DatabaseName": "TransactionDb",
      "ApplicationName": "TicketsApp-TransactionService",
      "AllowBulkExecution": true,
      "MaxRetryAttemptsOnRateLimitedRequests": 5,
      "MaxRetryWaitTimeOnRateLimitedRequests": 30
    },
    "TicketDb": {
      "EndpointUri": "https://{your-ticket-cosmos-account}.documents.azure.com:443/",
      "PrimaryKey": "{your-ticket-primary-key}",
      "DatabaseName": "TicketDb",
      "ApplicationName": "TicketsApp-TicketService",
      "AllowBulkExecution": true,
      "MaxRetryAttemptsOnRateLimitedRequests": 5,
      "MaxRetryWaitTimeOnRateLimitedRequests": 30
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Azure.Core": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}